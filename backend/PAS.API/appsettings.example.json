{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "{Connection_String}"
  },
  "JwtSettings": {
    "SecretKey": "{Your_Strong_Secret_Key_Min_32_Chars}",
    "Issuer": "PAS.API",
    "Audience": "PAS.Client",
    "ExpiryMinutes": "60"
  },
  "SmtpSettings": {
    "Host": "smtp.gmail.com",
    "Port": "587",
    "Username": "pas.verify.support@gmail.com",
    "Password": "{your-smtp-password}",
    "FromName": "PAS System",
    "FromAddress": "pas.verify.support@gmail.com"
  },
  "AzureBlobStorage": {
    "ConnectionString": "{Your_Azure_Storage_Connection_String}",
    "ContainerName": "submissions"
  }
}