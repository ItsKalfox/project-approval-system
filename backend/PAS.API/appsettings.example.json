{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "{Connection_String}"
  },
  "JwtSettings": {
    "SecretKey": "{Your_Strong_Secret_Key_Min_32_Chars}",
    "Issuer": "PAS.API",
    "Audience": "PAS.Client",
    "ExpiryMinutes": "60"
  },
  "SmtpSettings": {
    "Host": "{smtp.provider.com}",
    "Port": "587",
    "Username": "{your-email@domain.com}",
    "Password": "{your-smtp-password}",
    "FromName": "PAS System",
    "FromAddress": "{your-email@domain.com}"
  }
}