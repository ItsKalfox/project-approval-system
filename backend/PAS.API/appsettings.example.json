{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "{Connection_String}"
  },
  "JwtSettings": {
    "SecretKey": "{Your_Strong_Secret_Key_Min_32_Chars}",
    "Issuer": "PAS.API",
    "Audience": "PAS.Client",
    "ExpiryMinutes": "60"
  }
}